{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "replicaCount",
    "image",
    "serviceAccount",
    "config",
    "service",
    "persistence",
    "terminationGracePeriodSeconds"
  ],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "const": 1,
      "description": "Rustium currently requires one owner for each SQLite checkpoint and source position."
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "pullPolicy", "tag"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "tag": { "type": "string" }
      }
    },
    "imagePullSecrets": { "type": "array" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "automountServiceAccountToken", "annotations", "name"],
      "properties": {
        "create": { "type": "boolean" },
        "automountServiceAccountToken": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["existingSecret", "secretKey", "content"],
      "properties": {
        "existingSecret": { "type": "string" },
        "secretKey": { "type": "string", "minLength": 1 },
        "content": { "type": "string" }
      },
      "anyOf": [
        { "properties": { "existingSecret": { "minLength": 1 } } },
        { "properties": { "content": { "minLength": 1 } } }
      ]
    },
    "extraEnv": { "type": "array" },
    "envFrom": { "type": "array" },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "port", "annotations"],
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "annotations": { "type": "object" }
      }
    },
    "resources": { "type": "object" },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "existingClaim", "storageClass", "accessModes", "size", "annotations"],
      "properties": {
        "enabled": { "type": "boolean" },
        "existingClaim": { "type": "string" },
        "storageClass": { "type": "string" },
        "accessModes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "size": { "type": "string", "minLength": 1 },
        "annotations": { "type": "object" }
      }
    },
    "livenessProbe": { "$ref": "#/$defs/probe" },
    "readinessProbe": { "$ref": "#/$defs/probe" },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 30 },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "minAvailable"],
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": "integer", "minimum": 0, "maximum": 1 }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "namespace", "interval", "scrapeTimeout", "additionalLabels"],
      "properties": {
        "enabled": { "type": "boolean" },
        "namespace": { "type": "string" },
        "interval": { "type": "string" },
        "scrapeTimeout": { "type": "string" },
        "additionalLabels": { "type": "object" }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },
    "extraVolumes": { "type": "array" },
    "extraVolumeMounts": { "type": "array" }
  },
  "$defs": {
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "initialDelaySeconds", "periodSeconds", "timeoutSeconds", "failureThreshold"],
      "properties": {
        "enabled": { "type": "boolean" },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
